[Unit]
Description=Elite Dangerous Time Trial Leaderboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/srv/elite/timetrials-leaderboard/tt-leaderboard
ExecStart=/srv/elite/timetrials-leaderboard/tt-leaderboard/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8090
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
